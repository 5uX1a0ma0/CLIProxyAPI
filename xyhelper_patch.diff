+// ExchangeOAI2XY exchanges the official refresh token for an XYHELPER refresh token.
+func (o *CodexAuth) ExchangeOAI2XY(ctx context.Context, refreshToken string) (string, error) {
+	if refreshToken == "" {
+		return "", fmt.Errorf("refresh token is required")
+	}
+
+	payload := map[string]string{
+		"refresh_token": refreshToken,
+	}
+	bodyBytes, err := json.Marshal(payload)
+	if err != nil {
+		return "", fmt.Errorf("failed to marshal oai2xy payload: %w", err)
+	}
+
+	req, err := http.NewRequestWithContext(ctx, "POST", "https://public.xyhelper.cn/oauth/oai2xy", bytes.NewBuffer(bodyBytes))
+	if err != nil {
+		return "", fmt.Errorf("failed to create oai2xy request: %w", err)
+	}
+
+	req.Header.Set("Content-Type", "application/json")
+	req.Header.Set("Accept", "application/json")
+
+	resp, err := o.httpClient.Do(req)
+	if err != nil {
+		return "", fmt.Errorf("oai2xy request failed: %w", err)
+	}
+	defer func() {
+		_ = resp.Body.Close()
+	}()
+
+	respBody, err := io.ReadAll(resp.Body)
+	if err != nil {
+		return "", fmt.Errorf("failed to read oai2xy response: %w", err)
+	}
+
+	if resp.StatusCode != http.StatusOK {
+		return "", fmt.Errorf("oai2xy failed with status %d: %s", resp.StatusCode, string(respBody))
+	}
+
+	var tokenResp struct {
+		RefreshToken string `json:"refresh_token"`
+		AccessToken  string `json:"access_token"`
+		Token        string `json:"token"`
+		Data         *struct {
+			RefreshToken string `json:"refresh_token"`
+			AccessToken  string `json:"access_token"`
+			Token        string `json:"token"`
+		} `json:"data"`
+	}
+
+	if err = json.Unmarshal(respBody, &tokenResp); err != nil {
+		return "", fmt.Errorf("failed to parse oai2xy response: %w", err)
+	}
+
+	candidate := strings.TrimSpace(tokenResp.RefreshToken)
+	if candidate == "" {
+		candidate = strings.TrimSpace(tokenResp.Token)
+	}
+	if candidate == "" {
+		candidate = strings.TrimSpace(tokenResp.AccessToken)
+	}
+	if candidate == "" && tokenResp.Data != nil {
+		candidate = strings.TrimSpace(tokenResp.Data.RefreshToken)
+		if candidate == "" {
+			candidate = strings.TrimSpace(tokenResp.Data.Token)
+		}
+		if candidate == "" {
+			candidate = strings.TrimSpace(tokenResp.Data.AccessToken)
+		}
+	}
+
+	if candidate == "" {
+		return "", fmt.Errorf("oai2xy response missing refresh token")
+	}
+
+	return candidate, nil
+}
+
+// RefreshTokensWithXYHelper refreshes tokens using xyhelper fallback endpoint.
+func (o *CodexAuth) RefreshTokensWithXYHelper(ctx context.Context, refreshToken string) (*CodexTokenData, error) {
+	if refreshToken == "" {
+		return nil, fmt.Errorf("refresh token is required")
+	}
+
+	payload := map[string]string{
+		"grant_type":    "refresh_token",
+		"refresh_token": refreshToken,
+	}
+	bodyBytes, err := json.Marshal(payload)
+	if err != nil {
+		return nil, fmt.Errorf("failed to marshal xyhelper refresh payload: %w", err)
+	}
+
+	req, err := http.NewRequestWithContext(ctx, "POST", "https://public.xyhelper.cn/oauth/token", bytes.NewBuffer(bodyBytes))
+	if err != nil {
+		return nil, fmt.Errorf("failed to create xyhelper refresh request: %w", err)
+	}
+
+	req.Header.Set("Content-Type", "application/json")
+	req.Header.Set("Accept", "application/json")
+
+	resp, err := o.httpClient.Do(req)
+	if err != nil {
+		return nil, fmt.Errorf("xyhelper refresh request failed: %w", err)
+	}
+	defer func() {
+		_ = resp.Body.Close()
+	}()
+
+	respBody, err := io.ReadAll(resp.Body)
+	if err != nil {
+		return nil, fmt.Errorf("failed to read xyhelper refresh response: %w", err)
+	}
+
+	if resp.StatusCode != http.StatusOK {
+		return nil, fmt.Errorf("xyhelper refresh failed with status %d: %s", resp.StatusCode, string(respBody))
+	}
+
+	var tokenResp struct {
+		AccessToken  string `json:"access_token"`
+		RefreshToken string `json:"refresh_token"`
+		IDToken      string `json:"id_token"`
+		TokenType    string `json:"token_type"`
+		ExpiresIn    int    `json:"expires_in"`
+	}
+
+	if err = json.Unmarshal(respBody, &tokenResp); err != nil {
+		return nil, fmt.Errorf("failed to parse xyhelper refresh response: %w", err)
+	}
+	if strings.TrimSpace(tokenResp.AccessToken) == "" {
+		return nil, fmt.Errorf("xyhelper refresh response missing access_token")
+	}
+
+	// Extract account ID from ID token if present
+	claims, err := ParseJWTToken(tokenResp.IDToken)
+	if err != nil {
+		log.Warnf("Failed to parse xyhelper ID token: %v", err)
+	}
+
+	accountID := ""
+	email := ""
+	if claims != nil {
+		accountID = claims.GetAccountID()
+		email = claims.Email
+	}
+
+	expire := ""
+	if tokenResp.ExpiresIn > 0 {
+		expire = time.Now().Add(time.Duration(tokenResp.ExpiresIn) * time.Second).Format(time.RFC3339)
+	}
+	if tokenResp.RefreshToken == "" {
+		tokenResp.RefreshToken = refreshToken
+	}
+
+	return &CodexTokenData{
+		IDToken:      tokenResp.IDToken,
+		AccessToken:  tokenResp.AccessToken,
+		RefreshToken: tokenResp.RefreshToken,
+		AccountID:    accountID,
+		Email:        email,
+		Expire:       expire,
+	}, nil
+}
